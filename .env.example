# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# WhatsApp (Meta Cloud API) — used to deliver login OTP + webhook verification
# Meta callback URL: https://<your-host>/webhook  (GET verify uses hub.verify_token = WA_VERIFY_TOKEN)
WA_VERIFY_TOKEN=your-verify-token
WA_ACCESS_TOKEN=your-access-token
WA_PHONE_NUMBER_ID=your-phone-number-id

# Server-only: hash pepper for WhatsApp OTP codes (min 16 chars)
# openssl rand -hex 32
OTP_SECRET=your-long-random-secret-min-16-chars

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Resend (email)
RESEND_API_KEY=your-resend-api-key

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# App
NEXT_PUBLIC_APP_URL=https://your-app.up.railway.app
